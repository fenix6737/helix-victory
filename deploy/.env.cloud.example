# Oracle VM / docker compose 用 — deploy/.env.cloud にコピーして編集
POSTGRES_USER=helix
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=helix_victory
HELIX_HTTP_PORT=8080

ADMIN_USERNAME=helix_admin
ADMIN_PASSWORD=change-me-admin-password
JWT_SECRET=change-me-random-64-char-secret-minimum-length
INGEST_API_KEY=change-me-ingest-key

CORS_ORIGINS=http://YOUR_VM_PUBLIC_IP:8080,https://YOUR_DOMAIN

# 収集元（そのまま利用可）
