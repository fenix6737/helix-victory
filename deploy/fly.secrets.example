# Fly.io: 編集後に fly secrets set KEY=value ... または
#   fly secrets import < deploy/fly.secrets.local
#
# DB/Redis 無料枠（推奨）:
#   Neon https://neon.tech  → DATABASE_URL
#   Upstash https://upstash.com → REDIS_URL

DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST/helix_victory?sslmode=require
REDIS_URL=rediss://default:TOKEN@HOST:6379

ADMIN_USERNAME=helix_admin
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-random-64-char-secret
INGEST_API_KEY=change-me-ingest-key

CORS_ORIGINS=https://helix-victory.fly.dev

MARUHAN_UMEDA_URL=https://daidata.goraggio.com/207042
ANASLO_KICONA_LIST_URL=https://ana-slo.com/%E3%83%9B%E3%83%BC%E3%83%AB%E3%83%87%E3%83%BC%E3%82%BF/%E5%85%B5%E5%BA%AB%E7%9C%8C/%E3%82%AD%E3%82%B3%E3%83%BC%E3%83%8A%E5%B0%BC%E5%B4%8E%E6%9C%AC%E5%BA%97-%E3%83%87%E3%83%BC%E3%82%BF%E4%B8%80%E8%A6%A7/
MINREPO_LATEST_REPORT_URL=https://min-repo.com/3093761/
