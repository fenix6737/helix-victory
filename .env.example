# Database
# 本番: PostgreSQL（docker compose up -d）
DATABASE_URL=postgresql+asyncpg://helix:helix@localhost:5432/helix_victory
DATABASE_URL_SYNC=postgresql://helix:helix@localhost:5432/helix_victory
# ローカル簡易検証（Docker不要）: sqlite+aiosqlite:///helix_local.db

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
API_URL=http://localhost:8000
API_URL_INTERNAL=http://127.0.0.1:8000
PUBLIC_ACCESS=0

# 管理者認証（本番では必ず変更）
ADMIN_USERNAME=helix_admin
ADMIN_PASSWORD=HelixVictory2026!Admin
JWT_SECRET=replace-with-random-64-char-secret-in-production
JWT_EXPIRE_HOURS=24

# 収集サービス用（ingest API）
INGEST_API_KEY=helix-ingest-7f3a9c2e1b8d4f6a0c5e

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
# 金額換算（表示用）
NEXT_PUBLIC_SLOT_YEN_PER_MEDAL=20
NEXT_PUBLIC_PACHINKO_YEN_PER_BALL=4

